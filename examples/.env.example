# Copy this file to `.env` and fill in your key. `.env` is gitignored.
AMBERTRACE_API_KEY=at_your_key_here

# Optional — defaults to the hosted platform.
# AMBERTRACE_BASE_URL=https://app.ambertrace.ai

# Required only for the FRED examples (08, 09). Free key:
# https://fred.stlouisfed.org → My Account → API Keys
# FRED_API_KEY=your_fred_key
